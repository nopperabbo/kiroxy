# kiroxy env vars — copy to .env and fill in

# Inbound proxy API key (clients must send X-Api-Key or Authorization: Bearer <this>)
# Generate with: openssl rand -hex 32
KIROXY_API_KEY=

# Bind address. Default loopback-only. Set to 0.0.0.0 if you need remote access
# (ONLY do that behind a reverse proxy with TLS — this server does not do TLS itself).
KIROXY_BIND=127.0.0.1

# Listen port
KIROXY_PORT=8787

# Token vault SQLite path. Defaults to ~/.kiroxy/tokens.db if unset.
# KIROXY_DB_PATH=/Users/you/.kiroxy/tokens.db

# Log level: debug | info | warn | error
KIROXY_LOG_LEVEL=info

# Graceful shutdown timeout (seconds). Waits up to this long for in-flight SSE to flush.
KIROXY_SHUTDOWN_TIMEOUT=30

# Upstream Kiro region. Usually us-east-1 (the only region where CodeWhisperer lives).
KIROXY_KIRO_REGION=us-east-1

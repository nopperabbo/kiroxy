{
  "$schema": "https://tr.designtokens.org/format/#design-token-format-module",
  "$description": "kiroxy design tokens — canonical values for the dark theme. W3C Design Tokens Community Group draft format. Light, dark-dimmed, and high-contrast variants are declared in tokens.css and are NOT mirrored here because DTCG does not yet have a stable theming extension; consumers should treat the values below as 'dark theme' and parse the CSS file for the other themes. See docs/DESIGN_SYSTEM.md for the full specification.",
  "color": {
    "$description": "Semantic color tokens for the default dark theme. Hue 285 cool-neutral ramp + cyan-teal accent at hue 200. All values OKLCH; chroma kept <= 0.25 for sRGB safety (Safari/Chrome clip higher values — see DESIGN_SYSTEM.md §2.7).",
    "bg":             { "$value": "oklch(0.145 0.005 285)", "$type": "color", "$description": "Canvas — the deepest background layer" },
    "surface":        { "$value": "oklch(0.205 0.006 285)", "$type": "color", "$description": "Surface — cards, table rows, sidebar" },
    "elevated":       { "$value": "oklch(0.265 0.007 285)", "$type": "color", "$description": "Elevated — hover, popover, modal surface" },
    "border":         { "$value": "oklch(0.340 0.008 285)", "$type": "color", "$description": "Default 1px border" },
    "textDim":        { "$value": "oklch(0.660 0.015 285)", "$type": "color", "$description": "Secondary text, timestamps, metadata" },
    "textDefault":    { "$value": "oklch(0.830 0.012 285)", "$type": "color", "$description": "Body text" },
    "textBright":     { "$value": "oklch(0.970 0.003 285)", "$type": "color", "$description": "Headings, emphasis" },

    "accent":         { "$value": "oklch(0.720 0.130 200)", "$type": "color", "$description": "Cyan-teal primary accent" },
    "accentHover":    { "$value": "oklch(0.780 0.130 200)", "$type": "color", "$description": "Accent hover state" },
    "accentPressed":  { "$value": "oklch(0.660 0.130 200)", "$type": "color", "$description": "Accent pressed state" },

    "success":        { "$value": "oklch(0.720 0.180 145)", "$type": "color", "$description": "Healthy/running semantic color" },
    "warning":        { "$value": "oklch(0.800 0.165 85)",  "$type": "color", "$description": "Cooldown/caution semantic color" },
    "danger":         { "$value": "oklch(0.680 0.220 25)",  "$type": "color", "$description": "Failed/destructive semantic color" },
    "info":           { "$value": "oklch(0.720 0.130 240)", "$type": "color", "$description": "Informational semantic color" }
  },

  "font": {
    "$description": "Type families. Both SIL OFL 1.1; self-hosted as WOFF2. See DESIGN_SYSTEM.md §3.1.",
    "sans": {
      "$value": ["InterVariable", "Inter", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "system-ui", "sans-serif"],
      "$type":  "fontFamily",
      "$description": "UI sans — Inter Variable primary, system fallbacks"
    },
    "mono": {
      "$value": ["JetBrains Mono Variable", "JetBrains Mono", "ui-monospace", "SF Mono", "Menlo", "Consolas", "monospace"],
      "$type":  "fontFamily",
      "$description": "Data mono — JetBrains Mono Variable primary, system fallbacks"
    }
  },

  "type": {
    "$description": "Type sizes. Minor-third ratio (1.200), base 14px. NOT fluid — kiroxy is keyboard-first; fixed sizes beat clever sizes.",
    "size11": { "$value": "0.6875rem", "$type": "dimension", "$description": "11px — micro meta, keycap badges" },
    "size12": { "$value": "0.75rem",   "$type": "dimension", "$description": "12px — metadata, timestamps" },
    "size13": { "$value": "0.8125rem", "$type": "dimension", "$description": "13px — compact body (Linear 510 weight pattern)" },
    "size14": { "$value": "0.875rem",  "$type": "dimension", "$description": "14px — default body" },
    "size16": { "$value": "1rem",      "$type": "dimension", "$description": "16px — h3" },
    "size20": { "$value": "1.25rem",   "$type": "dimension", "$description": "20px — h2" },
    "size24": { "$value": "1.5rem",    "$type": "dimension", "$description": "24px — h1" },
    "size32": { "$value": "2rem",      "$type": "dimension", "$description": "32px — welcome hero only" }
  },

  "weight": {
    "$description": "Inter Variable weight axis values. 510 is Linear's body-text trick.",
    "regular":  { "$value": 400, "$type": "fontWeight", "$description": "Body weight" },
    "solid":    { "$value": 510, "$type": "fontWeight", "$description": "Linear body-text trick — slightly heavier than regular" },
    "medium":   { "$value": 560, "$type": "fontWeight", "$description": "UI labels, buttons" },
    "semibold": { "$value": 620, "$type": "fontWeight", "$description": "Headings" }
  },

  "lineHeight": {
    "$description": "Unitless line-height values, applied relative to font-size.",
    "tight":   { "$value": 1.20, "$type": "number", "$description": "Headings" },
    "snug":    { "$value": 1.40, "$type": "number", "$description": "UI default" },
    "normal":  { "$value": 1.55, "$type": "number", "$description": "Body prose" },
    "relaxed": { "$value": 1.70, "$type": "number", "$description": "Empty-state prose" }
  },

  "space": {
    "$description": "4px grid. Rhythms: 4, 8, 12, 16, 24, 32, 48, 64. Never 36 or 40.",
    "s0":  { "$value": "0",        "$type": "dimension", "$description": "Zero" },
    "s1":  { "$value": "0.25rem",  "$type": "dimension", "$description": "4px" },
    "s2":  { "$value": "0.5rem",   "$type": "dimension", "$description": "8px" },
    "s3":  { "$value": "0.75rem",  "$type": "dimension", "$description": "12px" },
    "s4":  { "$value": "1rem",     "$type": "dimension", "$description": "16px" },
    "s6":  { "$value": "1.5rem",   "$type": "dimension", "$description": "24px" },
    "s8":  { "$value": "2rem",     "$type": "dimension", "$description": "32px" },
    "s12": { "$value": "3rem",     "$type": "dimension", "$description": "48px" },
    "s16": { "$value": "4rem",     "$type": "dimension", "$description": "64px" }
  },

  "radius": {
    "$description": "Radii scale. 6 for inputs/buttons, 8 for cards, 12 for panels, 16 for modals. Never uniform.",
    "r0":    { "$value": "0",      "$type": "dimension", "$description": "Hard edges" },
    "r2":    { "$value": "2px",    "$type": "dimension", "$description": "Tight chips, keycap badges" },
    "r4":    { "$value": "4px",    "$type": "dimension", "$description": "Compact affordances" },
    "r6":    { "$value": "6px",    "$type": "dimension", "$description": "Inputs, buttons" },
    "r8":    { "$value": "8px",    "$type": "dimension", "$description": "Cards, popovers" },
    "r12":   { "$value": "12px",   "$type": "dimension", "$description": "Panels, drawer rail" },
    "r16":   { "$value": "16px",   "$type": "dimension", "$description": "Dialogs" },
    "rFull": { "$value": "9999px", "$type": "dimension", "$description": "Pills, status dots" }
  },

  "shadow": {
    "$description": "Minimal shadows. Dark-mode shadows are DARKER than the surface they elevate (Grafana pattern).",
    "subtle":   { "$value": "0 1px 0 0 oklch(0 0 0 / 0.35)",     "$type": "shadow", "$description": "Hairline bottom shadow for row separators" },
    "elevated": { "$value": "0 2px 8px oklch(0 0 0 / 0.45)",     "$type": "shadow", "$description": "Card / popover elevation" },
    "overlay":  { "$value": "0 8px 24px oklch(0.02 0 0 / 0.70)", "$type": "shadow", "$description": "Modal / drawer overlay (Grafana dark-pop pattern)" }
  },

  "ease": {
    "$description": "One default easing curve. Snap for toggles, spring reserved.",
    "default": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",     "$type": "cubicBezier", "$description": "Linear signature ease-out (universal 2026 ops-tool default)" },
    "snap":    { "$value": "cubic-bezier(0.3, 0, 0, 1)",        "$type": "cubicBezier", "$description": "Sharper in/out for state toggles" },
    "spring":  { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Subtle overshoot — reserved" }
  },

  "duration": {
    "$description": "Motion durations. All collapse to 0ms under prefers-reduced-motion: reduce.",
    "instant":  { "$value": "0ms",   "$type": "duration", "$description": "Selection highlight, focus ring" },
    "quick":    { "$value": "120ms", "$type": "duration", "$description": "Hover, popover, tooltip, command palette" },
    "moderate": { "$value": "200ms", "$type": "duration", "$description": "Dialog, drawer" },
    "slow":     { "$value": "320ms", "$type": "duration", "$description": "Cross-page view transition" },
    "flash":    { "$value": "600ms", "$type": "duration", "$description": "SSE row-update pulse (single-shot)" }
  },

  "z": {
    "$description": "Z-index scale. Never magic numbers.",
    "base":     { "$value": 0,   "$type": "number", "$description": "Document baseline" },
    "raised":   { "$value": 10,  "$type": "number", "$description": "Hover, row elevation" },
    "sticky":   { "$value": 100, "$type": "number", "$description": "Sticky sidebar / breadcrumb" },
    "dropdown": { "$value": 200, "$type": "number", "$description": "Select popout" },
    "drawer":   { "$value": 300, "$type": "number", "$description": "Right drawer" },
    "modal":    { "$value": 400, "$type": "number", "$description": "Dialog" },
    "popover":  { "$value": 500, "$type": "number", "$description": "Native [popover]" },
    "toast":    { "$value": 600, "$type": "number", "$description": "Toast stack" },
    "tooltip":  { "$value": 700, "$type": "number", "$description": "Hover tooltip" },
    "palette":  { "$value": 800, "$type": "number", "$description": "Command palette" },
    "max":      { "$value": 999, "$type": "number", "$description": "Emergency escape hatch" }
  },

  "layout": {
    "$description": "Layout sizing tokens. Linear 'inverted-L' chassis.",
    "sidebarWidth":     { "$value": "240px", "$type": "dimension", "$description": "Sidebar default width" },
    "sidebarCollapsed": { "$value": "56px",  "$type": "dimension", "$description": "Sidebar collapsed icon-rail" },
    "breadcrumbHeight": { "$value": "40px",  "$type": "dimension", "$description": "Top breadcrumb bar height" },
    "drawerWidth":      { "$value": "400px", "$type": "dimension", "$description": "Drawer default width" },
    "drawerWidthWide":  { "$value": "560px", "$type": "dimension", "$description": "Drawer wide (request inspector)" },
    "contentMaxProse":  { "$value": "72ch",  "$type": "dimension", "$description": "Prose max width" },
    "modalSimple":      { "$value": "480px", "$type": "dimension", "$description": "Simple modal width" },
    "modalWizard":      { "$value": "640px", "$type": "dimension", "$description": "Wizard modal width" },
    "modalFull":        { "$value": "800px", "$type": "dimension", "$description": "Full-form modal width" },
    "paletteWidth":     { "$value": "640px", "$type": "dimension", "$description": "Command palette width" },
    "paletteTopOffset": { "$value": "20vh",  "$type": "dimension", "$description": "Palette top anchor" }
  },

  "density": {
    "$description": "Dimensions for the 'comfortable' density mode. 'compact' variant overrides these in tokens.css via data-density='compact'.",
    "rowHeight":    { "$value": "36px", "$type": "dimension", "$description": "Table row height (comfortable)" },
    "cellPaddingX": { "$value": "12px", "$type": "dimension", "$description": "Table cell horizontal padding" },
    "buttonHeight": { "$value": "32px", "$type": "dimension", "$description": "Button height" },
    "inputHeight":  { "$value": "32px", "$type": "dimension", "$description": "Input height" },
    "cardPadding":  { "$value": "16px", "$type": "dimension", "$description": "Card padding" },
    "sidebarItem":  { "$value": "32px", "$type": "dimension", "$description": "Sidebar nav item height" }
  },

  "ui": {
    "$description": "Component-level aliases — prefer these over raw tokens in component CSS.",
    "ringWidth":     { "$value": "2px",                          "$type": "dimension", "$description": "Focus-visible ring width" },
    "ringOffset":    { "$value": "2px",                          "$type": "dimension", "$description": "Focus-visible ring offset" },
    "ringColor":     { "$value": "{color.accent}",               "$type": "color",     "$description": "Alias of color.accent for focus rings" },
    "dotSize":       { "$value": "8px",                          "$type": "dimension", "$description": "Status-dot canonical size" },
    "rowFlashColor": { "$value": "{color.success}",              "$type": "color",     "$description": "Alias of color.success for SSE row-flash" }
  },

  "$extensions": {
    "dev.kiroxy.meta": {
      "version": "1.0.0",
      "sourceOfTruth": "docs/DESIGN_SYSTEM.md",
      "runtimeFile":   "internal/server/assets/tokens/tokens.css",
      "typedFile":     "internal/server/assets/tokens/tokens.ts",
      "authored":      "2026-05-13",
      "theming":       "Only the default dark theme is mirrored in this JSON. tokens.css declares light, dark-dimmed, dark-highcontrast, and light-highcontrast via [data-theme] selectors. Consumers that need a full theme map should parse the CSS directly until DTCG ships a stable theme-overlay extension."
    }
  }
}

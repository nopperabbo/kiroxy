---
const docs = [
  { title: "README",        href: "https://github.com/nopperabbo/kiroxy#readme",                             hint: "quickstart, endpoints, env vars" },
  { title: "Architecture",  href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/ARCHITECTURE.md",    hint: "component-by-component internals" },
  { title: "Troubleshooting", href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/TROUBLESHOOTING.md", hint: "401s, refresh loops, SSE buffering" },
  { title: "OpenAI compat", href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/OPENAI.md",         hint: "Cursor, Continue, Cline, aider" },
  { title: "opencode",      href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/OPENCODE.md",       hint: "resolver-verified provider snippet" },
  { title: "Benchmarks",    href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/BENCHMARKS.md",     hint: "harness, numbers, caveats" },
  { title: "Metrics",       href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/METRICS.md",        hint: "prometheus catalog, PromQL queries" },
  { title: "Design system", href: "https://github.com/nopperabbo/kiroxy/blob/main/docs/DESIGN_SYSTEM.md",  hint: "tokens, principles, rubric" },
];
---
<section id="docs" aria-labelledby="docs-title" class="alt">
  <div class="container">
    <span class="eyebrow">docs</span>
    <h2 id="docs-title" class="section-heading">Every surface is documented.</h2>
    <p class="section-lead">
      No wiki drift, no "see Discord". Each doc lives in the repo next to
      the code it describes and is part of every release.
    </p>

    <ul class="grid" role="list">
      {docs.map((d) => (
        <li>
          <a class="doc" href={d.href} rel="noopener">
            <span class="doc-title">
              {d.title}
              <span class="arrow" aria-hidden="true">↗</span>
            </span>
            <span class="doc-hint">{d.hint}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--sp-3);
  }
  @media (max-width: 980px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 520px) {
    .grid { grid-template-columns: 1fr; }
  }
  .doc {
    display: grid;
    gap: var(--sp-2);
    padding: var(--sp-5) var(--sp-5);
    border: 1px solid var(--c-rule);
    border-radius: var(--r-md);
    background: var(--c-surface-sunken);
    color: var(--c-text) !important;
    text-decoration: none !important;
    transition:
      border-color var(--mo-fast) var(--ease-std),
      background var(--mo-fast) var(--ease-std);
  }
  .doc:hover {
    border-color: var(--c-accent);
    background: var(--c-surface-2);
  }
  .doc-title {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: var(--fw-medium);
    color: var(--c-text);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .arrow {
    color: var(--c-accent);
    transition: transform var(--mo-fast) var(--ease-std);
    font-family: var(--font-display);
  }
  .doc:hover .arrow { transform: translate(2px, -2px); }
  .doc-hint {
    font-family: var(--font-text);
    font-size: var(--fs-xs);
    color: var(--c-text-faint);
    line-height: var(--lh-snug);
  }
</style>
